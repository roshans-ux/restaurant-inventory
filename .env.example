# Local DB (run `npm run db:start` first, then paste the URL it prints)
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# Session signing (min 16 characters; required in production)
SESSION_SECRET="change-me-to-a-long-random-string"

# Optional: credentials for `npm run seed` demo account (local dev only)
SEED_ADMIN_EMAIL="admin@demo.local"
SEED_ADMIN_PASSWORD="changeme123"

# Google Apps Script web app URL (POST) for onboarding signups — do not commit real URL
GOOGLE_SHEETS_WEBHOOK_URL=""

# Default webhook HMAC secret for new tenants (each tenant also stores its own copy)
POS_WEBHOOK_SECRET="dev-secret"

# Set to "true" to skip login (testing only — never on a public production site)
DISABLE_AUTH="false"
# Required on Netlify so Edge middleware sees the flag — set both to "true" when testing
NEXT_PUBLIC_DISABLE_AUTH="false"

# Transactional email (Resend) — verification + password reset
RESEND_API_KEY=""
# Verified sender in Resend, e.g. "Bar Inventory <noreply@yourdomain.com>"
EMAIL_FROM="Bar Inventory <onboarding@resend.dev>"
# Public site URL for links in emails (required in production)
APP_URL="http://localhost:3000"

# Optional: alert email integration
ADMIN_NOTIFICATION_EMAIL=""
